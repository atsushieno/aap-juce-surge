diff --git a/libs/luajitlib/build-android-luajit.sh b/libs/luajitlib/build-android-luajit.sh
new file mode 100755
index 00000000..80845a21
--- /dev/null
+++ b/libs/luajitlib/build-android-luajit.sh
@@ -0,0 +1,90 @@
+#!/bin/bash
+# Cross-compile LuaJIT for Android using NDK
+
+error=0
+
+BD="$1"
+NDK="$2"
+ABI="${3:-arm64-v8a}"
+PLATFORM="${4:-android-29}"
+
+if [[ -z "${BD}" || -z "${NDK}" ]]; then
+    echo "Usage: build-android-luajit.sh BUILDDIR NDK_DIR [ABI] [PLATFORM]"
+    exit 1
+fi
+
+API_LEVEL="${PLATFORM#android-}"
+
+echo "Building LuaJIT for Android: ABI=${ABI}, API=${API_LEVEL}"
+echo "Build dir: ${BD}"
+echo "NDK: ${NDK}"
+
+SD="${BD}/src"
+OD="${BD}/bin"
+HD="${BD}/include"
+
+rm -rf "${BD}" || error=1
+mkdir -p "${BD}" || error=1
+mkdir "${SD}" || error=1
+mkdir "${OD}" || error=1
+mkdir "${HD}" || error=1
+
+if [[ "$(uname)" == "Darwin" ]]; then
+    TOOLCHAIN="${NDK}/toolchains/llvm/prebuilt/darwin-x86_64"
+else
+    TOOLCHAIN="${NDK}/toolchains/llvm/prebuilt/linux-x86_64"
+fi
+
+case "${ABI}" in
+    arm64-v8a)
+        TRIPLE="aarch64-linux-android${API_LEVEL}"
+        ;;
+    armeabi-v7a)
+        TRIPLE="armv7a-linux-androideabi${API_LEVEL}"
+        ;;
+    x86)
+        TRIPLE="i686-linux-android${API_LEVEL}"
+        ;;
+    x86_64)
+        TRIPLE="x86_64-linux-android${API_LEVEL}"
+        ;;
+    *)
+        echo "Unsupported ABI: ${ABI}"
+        exit 1
+        ;;
+esac
+
+NDK_CC="${TOOLCHAIN}/bin/${TRIPLE}-clang"
+NDK_AR="${TOOLCHAIN}/bin/llvm-ar"
+NDK_RANLIB="${TOOLCHAIN}/bin/llvm-ranlib"
+
+echo "${OD}"
+ls -al "${OD}" || error=1
+echo "${HD}"
+ls -al "${HD}" || error=1
+
+cp -r LuaJIT "${SD}" || error=1
+cd "${SD}/LuaJIT/src" || error=1
+
+make amalg BUILDMODE=static \
+    HOST_CC="clang" \
+    CC="${NDK_CC}" \
+    TARGET_AR="${NDK_AR} rcus" \
+    RANLIB="${NDK_RANLIB}" \
+    TARGET_SYS=Linux \
+    TARGET_FLAGS="-fPIC" \
+    CFLAGS="-fPIC" || error=1
+
+cp lib*a "${OD}" || error=1
+cp *.h "${HD}" || error=1
+cp *.hpp "${HD}" 2>/dev/null || true
+
+echo "${OD}"
+ls -al "${OD}"
+echo "${HD}"
+ls -al "${HD}"
+
+if [ "${error}" -ne 0 ]; then
+    exit 1
+fi
+exit 0
